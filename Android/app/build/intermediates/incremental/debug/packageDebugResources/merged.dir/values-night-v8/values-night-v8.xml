<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bootstrap_warning">#FFC107</color>
    <color name="card_stroke_color">#1E88E5</color>
    <color name="colorOnPrimary">#FFFFFF</color>
    <color name="colorOnSurface">#FFFFFF</color>
    <color name="colorPrimary">#0061C1</color>
    <color name="colorPrimaryContainer">#0061C1</color>
    <color name="colorSurface">#000000</color>
    <color name="colorSurfaceVariant">@android:color/black</color>
    <color name="fundocartao">#000000</color>
    <color name="header_bg">#2A2A2A</color>
    <color name="icon_tint">#FFFFFF</color>
    <color name="md_theme_light_surfaceVariant">#F3EDF7</color>
    <color name="nav_bar_dark">#00070F</color>
    <color name="nav_bar_light">#B3FFFFFF</color>
    <color name="status_bar_dark_fallback">#FF000000</color>
    <color name="white">#FFFFFF</color>
    <style name="AppCardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/fundocartao</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="Theme.FEI" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="android:statusBarColor">@color/fundocartao</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="colorSurfaceVariant">@android:color/black</item>
        <item name="android:forceDarkAllowed">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="toolbarStyle">@style/Widget.FEI.TopAppBar</item>
        <item name="bottomNavigationStyle">@style/Widget.FEI.BottomNavigationView</item>
    </style>
    <style name="Widget.FEI.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconSize">32dp</item>
        <item name="itemPaddingTop">8dp</item>
        <item name="itemPaddingBottom">8dp</item>
        <item name="itemIconTint">@color/selector_bottom_nav_item_color</item>
        <item name="itemTextColor">@color/selector_bottom_nav_item_color</item>
        <item name="android:background">@color/fundocartao</item>
    </style>
    <style name="Widget.FEI.NavigationRailView" parent="Widget.Material3.NavigationRailView">
        <item name="itemIconTint">@color/selector_bottom_nav_item_color</item>
        <item name="itemTextColor">@color/selector_bottom_nav_item_color</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@color/fundocartao</item>
    </style>
    <style name="Widget.FEI.TopAppBar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/fundocartao</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="navigationIconTint">?attr/colorOnSurface</item>
        <item name="android:iconTint">?attr/colorOnSurface</item>
        <item name="android:elevation">0dp</item>
    </style>
</resources>