<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipe_refresh_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/fundocartao">

        <!-- Container de Carregamento -->
        <FrameLayout
            android:id="@+id/loadingContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_gravity="center">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:indicatorColor="?attr/colorPrimary"
                    android:indeterminate="true"
                    app:trackColor="?attr/colorSurfaceVariant" />

                <TextView
                    android:id="@+id/txtStuckHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carregando..."
                    android:layout_marginTop="16dp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:visibility="visible"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Conteúdo Principal para Tablet com Coluna Central -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.core.widget.NestedScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:fillViewport="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintWidth_max="@dimen/max_card_width_home">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Barra de Carregamento no Topo -->
                    <LinearLayout
                        android:id="@+id/top_loading_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:gravity="center"
                        android:background="@color/fundocartao"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:indeterminate="true"
                            app:indicatorSize="18dp"
                            app:trackCornerRadius="9dp"
                            app:indicatorColor="?attr/colorPrimary"
                            app:trackColor="?attr/colorSurfaceVariant" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Carregando dados..."
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <!-- Container do Carrossel -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/carousel_height_tablet"
                        android:layout_marginHorizontal="@dimen/carousel_margin"
                        android:layout_marginVertical="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <androidx.viewpager2.widget.ViewPager2
                                android:id="@+id/viewPager"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:clipToPadding="false"
                                android:clipChildren="false"
                                android:overScrollMode="never"
                                android:visibility="visible" />

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/carouselLoadingIndicator"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_gravity="center"
                                android:visibility="gone"
                                app:indicatorColor="?attr/colorPrimary"
                                app:trackColor="?attr/colorSurfaceVariant" />
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Seção de Notas -->
                    <LinearLayout
                        android:id="@+id/recentGradesSectionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="24dp"
                        android:padding="8dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Notas"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="22sp"
                            android:layout_marginBottom="12dp"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="4dp">

                            <TableLayout
                                android:id="@+id/tableRecentGrades"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:shrinkColumns="*"
                                android:stretchColumns="*"
                                android:background="@color/fundocartao" />

                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!--
                        Seção do Anúncio Nativo.
                        O título "Anúncio" fica aqui, fora do NativeAdView, alinhado com
                        os demais títulos de seção (Notas, Aulas do dia).
                        adSection controla a visibilidade de toda a seção via código.
                        adContainer é o slot onde o NativeAdView é inserido dinamicamente.
                    -->
                    <LinearLayout
                        android:id="@+id/adSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="24dp"
                        android:padding="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Anúncio"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="22sp"
                            android:layout_marginBottom="12dp"/>

                        <FrameLayout
                            android:id="@+id/adContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Seção de Aulas do Dia -->
                    <LinearLayout
                        android:id="@+id/aulasSectionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="24dp"
                        android:padding="8dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Aulas do dia"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="22sp"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:id="@+id/aulasContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <TextView
                            android:id="@+id/txtSemAulas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nenhuma aula hoje"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:padding="16dp"
                            android:visibility="gone" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Tela Offline -->
        <LinearLayout
            android:id="@+id/layout_sem_internet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/fundocartao"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_sem_internet"
                app:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/sem_internet"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tentar_novamente"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="TENTAR NOVAMENTE" />
        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>