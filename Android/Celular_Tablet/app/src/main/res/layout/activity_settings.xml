<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/fundocartao">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="?attr/colorOnSurface"
        app:title="Configurações"
        app:titleTextColor="?attr/colorOnSurface"
        app:elevation="0dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingHorizontal="16dp">

            <!-- Seção: Atualizações -->
            <com.google.android.material.textview.MaterialTextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Atualizações"
                android:paddingVertical="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/fundocartao"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_check_update"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:gravity="start|center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="Verificar atualizações do app"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        app:icon="@drawable/ic_update"
                        app:iconTint="?attr/colorOnSurfaceVariant"
                        app:iconGravity="start"
                        app:iconPadding="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Seção: Aplicativo -->
            <com.google.android.material.textview.MaterialTextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aplicativo"
                android:paddingVertical="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/fundocartao"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Linha: Ativar funcionalidade total -->
                    <LinearLayout
                        android:id="@+id/row_total_feature"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_total_feature"
                            android:contentDescription="Funcionalidade total"
                            app:tint="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Ativar funcionalidade total"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_full_feature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Seção: Dados -->
            <com.google.android.material.textview.MaterialTextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dados"
                android:paddingVertical="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/fundocartao"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_data"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:gravity="start|center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="Limpar dados"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        app:icon="@drawable/ic_delete_sweep"
                        app:iconTint="?attr/colorOnSurfaceVariant"
                        app:iconGravity="start"
                        app:iconPadding="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Seção: Segurança -->
            <com.google.android.material.textview.MaterialTextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Segurança"
                android:paddingVertical="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/fundocartao"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginVertical="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_password"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:gravity="start|center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="Limpar senhas e credenciais salvas"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        app:icon="@drawable/ic_security"
                        app:iconTint="?attr/colorOnSurfaceVariant"
                        app:iconGravity="start"
                        app:iconPadding="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Seção: GitHub -->
            <com.google.android.material.textview.MaterialTextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GitHub"
                android:paddingVertical="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/fundocartao"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginVertical="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_github"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:gravity="start|center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="etapaapp"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        app:icon="@drawable/ic_github"
                        app:iconTint="?attr/colorOnSurfaceVariant"
                        app:iconGravity="start"
                        app:iconPadding="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>